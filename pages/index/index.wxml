<!-- pages/index/index.wxml - 首页 -->
<view class="page-container">

  <!-- ====== 未登录状态 ====== -->
  <block wx:if="{{!isLogin}}">
    <view class="login-banner">
      <view class="login-content">
        <text style="font-size:100rpx;">🐭</text>
        <text class="text-xl text-bold mt-16">跑刀鼠</text>
        <text class="text-sm text-secondary mt-8">三角洲行动跑刀接单平台</text>
        <text class="text-sm text-secondary mt-4">专业打手 · 安全保障 · 高效交付</text>
        <button class="btn-primary login-btn" bindtap="startLogin">立即登录</button>
      </view>
    </view>
  </block>

  <!-- ====== 已登录状态 ====== -->
  <block wx:else>
    <!-- 顶部区域 -->
    <view class="header-section">
      <view class="header-top">
        <view class="header-user flex-row">
          <image class="avatar" src="{{userAvatar || '/images/default-avatar.png'}}" mode="aspectFill" />
          <view class="ml-8">
            <text class="text-lg text-bold">{{userNickName || '跑刀鼠用户'}}</text>
            <view class="flex-row mt-8">
              <text class="tag tag-pending">{{userRole === 'boss' ? '老板' : userRole === 'admin' ? '管理员' : '打手'}}</text>
            </view>
          </view>
        </view>
      </view>

      <!-- 轮播图 -->
      <swiper class="banner-swiper" indicator-dots="{{true}}" indicator-color="rgba(255,255,255,0.3)" indicator-active-color="#F5A623" autoplay="{{true}}" interval="4000" duration="500" circular="{{true}}" bindchange="onBannerChange">
        <swiper-item wx:for="{{banners}}" wx:key="id">
          <view class="banner-item">
            <view class="banner-content">
              <text class="banner-title">{{item.title}}</text>
              <text class="banner-desc">{{item.desc}}</text>
            </view>
          </view>
        </swiper-item>
      </swiper>
    </view>

    <!-- 快捷入口 -->
    <view class="quick-actions">
      <!-- 老板专属 -->
      <block wx:if="{{userRole === 'boss'}}">
        <view class="action-item" bindtap="goPublish">
          <view class="action-icon" style="background: rgba(245,166,35,0.15);">
            <text style="font-size:44rpx;">📝</text>
          </view>
          <text class="action-text">发布订单</text>
        </view>
        <view class="action-item" bindtap="goMyOrders">
          <view class="action-icon" style="background: rgba(155,89,182,0.15);">
            <text style="font-size:44rpx;">📦</text>
          </view>
          <text class="action-text">我的订单</text>
        </view>
        <view class="action-item" bindtap="switchToPlayer">
          <view class="action-icon" style="background: rgba(52,152,219,0.15);">
            <text style="font-size:44rpx;">🔄</text>
          </view>
          <text class="action-text">切换打手</text>
        </view>
      </block>

      <!-- 打手专属 -->
      <block wx:if="{{userRole === 'player'}}">
        <view class="action-item" bindtap="goVerify">
          <view class="action-icon" style="background: rgba(46,204,113,0.15);">
            <text style="font-size:44rpx;">🛡️</text>
          </view>
          <text class="action-text">{{isVerified ? '已认证' : '认证打手'}}</text>
        </view>
        <view class="action-item" bindtap="goMyOrders">
          <view class="action-icon" style="background: rgba(155,89,182,0.15);">
            <text style="font-size:44rpx;">📦</text>
          </view>
          <text class="action-text">我的接单</text>
        </view>
        <view class="action-item" bindtap="switchToBoss">
          <view class="action-icon" style="background: rgba(52,152,219,0.15);">
            <text style="font-size:44rpx;">🔄</text>
          </view>
          <text class="action-text">切换老板</text>
        </view>
      </block>

      <!-- 管理员专属 -->
      <block wx:if="{{userRole === 'admin'}}">
        <view class="action-item" bindtap="goAdmin">
          <view class="action-icon" style="background: rgba(46,204,113,0.15);">
            <text style="font-size:44rpx;">⚙️</text>
          </view>
          <text class="action-text">管理后台</text>
        </view>
        <view class="action-item" bindtap="goPublish">
          <view class="action-icon" style="background: rgba(245,166,35,0.15);">
            <text style="font-size:44rpx;">📝</text>
          </view>
          <text class="action-text">发布订单</text>
        </view>
        <view class="action-item" bindtap="goMyOrders">
          <view class="action-icon" style="background: rgba(155,89,182,0.15);">
            <text style="font-size:44rpx;">📦</text>
          </view>
          <text class="action-text">我的订单</text>
        </view>
      </block>

      <!-- 公用入口 -->
      <view class="action-item" bindtap="goOrderHall">
        <view class="action-icon" style="background: rgba(245,166,35,0.1);">
          <text style="font-size:44rpx;">📋</text>
        </view>
        <text class="action-text">订单大厅</text>
      </view>
    </view>

    <!-- 推荐打手 -->
    <view class="section" wx:if="{{userRole === 'boss' || userRole === 'admin'}}">
      <view class="section-header flex-between px-24">
        <text class="text-lg text-bold">🔥 推荐打手</text>
        <text class="text-sm text-accent">查看更多 ▸</text>
      </view>
      <scroll-view class="player-scroll" scroll-x="{{true}}" show-scrollbar="{{false}}">
        <view class="player-list">
          <view class="player-card" wx:for="{{hotPlayers}}" wx:key="_id" bindtap="goPlayerDetail" data-id="{{item._id}}">
            <image class="avatar avatar-sm" src="{{item.avatarUrl || '/images/default-avatar.png'}}" mode="aspectFill" />
            <text class="text-sm text-bold mt-8">{{item.nickName}}</text>
            <view class="flex-row mt-8">
              <text class="text-xs text-accent">★ {{item.rating || 5.0}}</text>
            </view>
            <text class="text-xs text-muted mt-4">已接{{item.orderCount || 0}}单</text>
          </view>
          <view class="player-card player-card-empty" wx:if="{{hotPlayers.length === 0 && !loading}}">
            <text class="text-sm text-muted">暂无推荐打手</text>
          </view>
        </view>
      </scroll-view>
    </view>

    <!-- 最新订单 -->
    <view class="section">
      <view class="section-header flex-between px-24">
        <text class="text-lg text-bold">📌 最新订单</text>
        <text class="text-sm text-accent" bindtap="goOrderHall">查看全部 ▸</text>
      </view>
      <view class="order-list">
        <block wx:for="{{recentOrders}}" wx:key="_id">
          <order-card order="{{item}}" bindtap="goOrderDetail" data-id="{{item._id}}" />
        </block>
        <view class="empty-state" wx:if="{{recentOrders.length === 0 && !loading}}">
          <text style="font-size:60rpx;">📭</text>
          <text>暂无订单，快去发布吧</text>
        </view>
      </view>
    </view>
  </block>

  <!-- 加载状态 -->
  <view class="load-more" wx:if="{{loading}}">
    <text>加载中...</text>
  </view>
</view>
