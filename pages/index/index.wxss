/* pages/index/index.wxss - 首页样式 */

.header-section {
  padding-top: 20rpx;
}

.header-top {
  padding: 20rpx 24rpx;
}

.header-user {
  align-items: center;
}

/* 轮播图 */
.banner-swiper {
  width: 692rpx;
  height: 280rpx;
  margin: 16rpx 29rpx;
  border-radius: 16rpx;
  overflow: hidden;
}

.banner-item {
  width: 100%;
  height: 100%;
  background: linear-gradient(135deg, #1A2435, #151E2C);
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 32rpx;
  box-sizing: border-box;
}

.banner-content {
  text-align: center;
}

.banner-title {
  display: block;
  font-size: 36rpx;
  font-weight: 700;
  color: #F5A623;
  margin-bottom: 12rpx;
}

.banner-desc {
  display: block;
  font-size: 26rpx;
  color: #A0B0C0;
}

/* 快捷入口 */
.quick-actions {
  display: flex;
  flex-direction: row;
  justify-content: space-around;
  padding: 24rpx 16rpx;
  margin: 0 24rpx;
  background: var(--bg-card);
  border-radius: var(--border-radius);
  border: 1px solid var(--border-color);
}

.action-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 16rpx 20rpx;
}

.action-icon {
  width: 80rpx;
  height: 80rpx;
  border-radius: 20rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 8rpx;
}

.action-text {
  font-size: 22rpx;
  color: var(--text-secondary);
}

/* 区块标题 */
.section {
  margin-top: 32rpx;
}

.section-header {
  margin-bottom: 16rpx;
}

/* 推荐打手横向滚动 */
.player-scroll {
  width: 100%;
  white-space: nowrap;
}

.player-list {
  display: flex;
  flex-direction: row;
  padding: 0 24rpx;
}

.player-card {
  display: flex;
  flex-direction: column;
  align-items: center;
  background: var(--bg-card);
  border-radius: var(--border-radius);
  border: 1px solid var(--border-color);
  padding: 24rpx 28rpx;
  margin-right: 16rpx;
  min-width: 160rpx;
  flex-shrink: 0;
}

.player-card-empty {
  min-width: 200rpx;
  justify-content: center;
  min-height: 120rpx;
}

/* 订单列表 */
.order-list {
  padding: 0 24rpx;
}

/* 未登录界面 */
.login-banner {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 120rpx 24rpx;
  min-height: 80vh;
}

.login-content {
  display: flex;
  flex-direction: column;
  align-items: center;
  text-align: center;
}

.login-btn {
  margin-top: 60rpx;
  width: 500rpx;
  padding: 24rpx 0;
}

/* ====== 弹窗样式 ====== */
.modal-overlay {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.6);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 9999;
}

.modal-box {
  width: 580rpx;
  background: #1A2435;
  border-radius: 16rpx;
  border: 1px solid #2A3A50;
  overflow: hidden;
}

.modal-header {
  padding: 32rpx 32rpx 8rpx;
  text-align: center;
}

.modal-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #E8ECF1;
}

.modal-subtitle {
  font-size: 24rpx;
  color: #8899AA;
  display: block;
  margin-top: 8rpx;
}

.modal-body {
  padding: 16rpx 32rpx 24rpx;
}

.modal-input {
  width: 100%;
  height: 80rpx;
  padding: 0 20rpx;
  background: #0D1520;
  border: 1px solid #2A3A50;
  border-radius: 12rpx;
  color: #E8ECF1;
  font-size: 28rpx;
  box-sizing: border-box;
}

.modal-footer {
  display: flex;
  border-top: 1px solid #2A3A50;
}

.modal-btn {
  flex: 1;
  height: 96rpx;
  line-height: 96rpx;
  text-align: center;
  font-size: 30rpx;
  border: none;
  border-radius: 0;
  background: transparent;
  padding: 0;
}

.modal-btn::after {
  border: none;
}

.modal-btn-cancel {
  color: #8899AA;
  border-right: 1px solid #2A3A50;
}

.modal-btn-confirm {
  color: #F5A623;
  font-weight: 600;
}
