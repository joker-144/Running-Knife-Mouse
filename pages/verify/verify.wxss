/* pages/verify/verify.wxss - ТЅЊТЅІУ«цУ»ЂТаит╝Ј */

.form-scroll {
  height: 100vh;
}

/* У«цУ»ЂуіХТђЂтЇАуЅ?*/
.verify-card {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 80rpx 24rpx;
  margin: 24rpx;
  border-radius: var(--border-radius);
  border: 1px solid var(--border-color);
  text-align: center;
}

.verify-approved {
  background: linear-gradient(135deg, rgba(46,204,113,0.1), rgba(46,204,113,0.05));
  border-color: rgba(46,204,113,0.3);
}

.verify-pending {
  background: linear-gradient(135deg, rgba(77, 159, 255,0.1), rgba(77, 159, 255,0.05));
  border-color: rgba(77, 159, 255,0.3);
}

.verify-rejected {
  background: linear-gradient(135deg, rgba(231,76,60,0.1), rgba(231,76,60,0.05));
  border-color: rgba(231,76,60,0.3);
}

/* УАетЇЋтї║тЮЌ */
.form-section {
  padding: 24rpx;
  margin: 16rpx 24rpx;
  background: var(--bg-card);
  border-radius: var(--border-radius);
  border: 1px solid var(--border-color);
}

.form-label {
  display: block;
  margin-bottom: 16rpx;
  font-size: 28rpx;
}

.form-input {
  padding: 20rpx 16rpx;
  background: var(--bg-primary);
  border: 2rpx solid var(--border-color);
  border-radius: var(--border-radius-sm);
  font-size: 28rpx;
  color: var(--text-primary);
}

.form-textarea {
  width: 100%;
  min-height: 120rpx;
  padding: 16rpx;
  background: var(--bg-primary);
  border: 2rpx solid var(--border-color);
  border-radius: var(--border-radius-sm);
  font-size: 26rpx;
  color: var(--text-primary);
  box-sizing: border-box;
}

/* тЏЙуЅЄСИіС╝а */
.image-upload-grid {
  display: flex;
  flex-direction: row;
  flex-wrap: wrap;
  gap: 12rpx;
}

.image-item {
  position: relative;
  width: 200rpx;
  height: 200rpx;
  border-radius: var(--border-radius-sm);
  overflow: hidden;
}

.image-thumb {
  width: 100%;
  height: 100%;
}

.image-delete {
  position: absolute;
  top: 4rpx;
  right: 4rpx;
  width: 40rpx;
  height: 40rpx;
  border-radius: 50%;
  background: rgba(231,76,60,0.9);
  display: flex;
  align-items: center;
  justify-content: center;
  color: #FFF;
  font-size: 24rpx;
}

.image-add {
  width: 200rpx;
  height: 200rpx;
  border: 2rpx dashed var(--border-color);
  border-radius: var(--border-radius-sm);
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
}

.submit-area {
  padding: 32rpx 0;
}
