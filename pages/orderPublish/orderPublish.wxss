/* pages/orderPublish/orderPublish.wxss - еЏ‘еёѓи®ўеЌ•ж ·ејЏ */

.form-scroll {
  height: 100vh;
}

.form-section {
  padding: 24rpx;
  margin: 16rpx 24rpx;
  background: var(--bg-card);
  border-radius: var(--border-radius);
  border: 1px solid var(--border-color);
}

.form-label {
  display: block;
  margin-bottom: 16rpx;
  font-size: 28rpx;
}

/* жњЌеЉЎз±»ећ‹зЅ‘ж ј */
.service-type-grid {
  display: flex;
  flex-direction: row;
  gap: 16rpx;
}

.service-type-item {
  flex: 1;
  padding: 20rpx 16rpx;
  background: var(--bg-primary);
  border: 2rpx solid var(--border-color);
  border-radius: var(--border-radius-sm);
  text-align: center;
  transition: all 0.2s;
}

.service-type-item.active {
  border-color: var(--accent);
  background: var(--accent-light);
}

.service-type-label {
  display: block;
  font-size: 28rpx;
  font-weight: 600;
  color: var(--text-primary);
  margin-bottom: 4rpx;
}

.service-type-desc {
  display: block;
  font-size: 20rpx;
}

/* иЎЁеЌ•йЂ‰ж‹©е™?*/
.form-picker {
  display: flex;
  flex-direction: row;
  align-items: center;
  justify-content: space-between;
  padding: 20rpx 16rpx;
  background: var(--bg-primary);
  border: 2rpx solid var(--border-color);
  border-radius: var(--border-radius-sm);
}

.form-input {
  padding: 20rpx 16rpx;
  background: var(--bg-primary);
  border: 2rpx solid var(--border-color);
  border-radius: var(--border-radius-sm);
  font-size: 28rpx;
  color: var(--text-primary);
}

.form-textarea {
  width: 100%;
  min-height: 120rpx;
  padding: 16rpx;
  background: var(--bg-primary);
  border: 2rpx solid var(--border-color);
  border-radius: var(--border-radius-sm);
  font-size: 28rpx;
  color: var(--text-primary);
  box-sizing: border-box;
}

/* д»·ж јз±»ећ‹е€‡жЌў */
.price-type-switch {
  background: var(--bg-primary);
  border-radius: 8rpx;
  padding: 4rpx;
  margin-bottom: 16rpx;
}

.price-type-item {
  flex: 1;
  text-align: center;
  padding: 12rpx 0;
  border-radius: 6rpx;
  font-size: 26rpx;
  color: var(--text-muted);
  transition: all 0.2s;
}

.price-type-item.active {
  background: var(--accent);
  color: #0A0E17;
  font-weight: 600;
}

.price-input-row {
  padding: 16rpx;
  background: var(--bg-primary);
  border: 2rpx solid var(--border-color);
  border-radius: var(--border-radius-sm);
}

.price-input {
  font-size: 32rpx;
  color: var(--accent);
}

/* е›ѕз‰‡дёЉдј  */
.image-upload-grid {
  display: flex;
  flex-direction: row;
  flex-wrap: wrap;
  gap: 16rpx;
}

.image-item {
  position: relative;
  width: 200rpx;
  height: 200rpx;
  border-radius: var(--border-radius-sm);
  overflow: hidden;
}

.image-thumb {
  width: 100%;
  height: 100%;
}

.image-delete {
  position: absolute;
  top: 4rpx;
  right: 4rpx;
  width: 40rpx;
  height: 40rpx;
  border-radius: 50%;
  background: rgba(231, 76, 60, 0.9);
  display: flex;
  align-items: center;
  justify-content: center;
  color: #FFFFFF;
  font-size: 24rpx;
}

.image-add {
  width: 200rpx;
  height: 200rpx;
  border: 2rpx dashed var(--border-color);
  border-radius: var(--border-radius-sm);
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  color: var(--text-muted);
}

/* жЏђдє¤жЊ‰й’®еЊєеџџ */
.submit-area {
  padding-top: 32rpx;
  padding-bottom: 32rpx;
}

.submit-area .btn-primary {
  width: 100%;
}

/* йЂ‰ж‹©е™Ёеј№зЄ?*/
.picker-overlay {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.6);
  z-index: 1000;
  display: flex;
  align-items: flex-end;
}

.picker-panel {
  width: 100%;
  max-height: 60vh;
  background: var(--bg-card);
  border-radius: 24rpx 24rpx 0 0;
  overflow: hidden;
}

.picker-header {
  border-bottom: 1px solid var(--border-color);
}

.picker-body {
  padding: 0 24rpx;
  max-height: 40vh;
  overflow-y: auto;
}

.picker-item {
  padding: 28rpx 16rpx;
  border-bottom: 1px solid var(--border-color);
  font-size: 28rpx;
}

.picker-item.active {
  color: var(--accent);
}
