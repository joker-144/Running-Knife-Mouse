/* зӯӣйҖүж Ҹ */
.filter-bar {
  display: flex;
  flex-direction: row;
  align-items: center;
  padding: 16rpx 24rpx;
  background: var(--bg-card);
  border-bottom: 1px solid var(--border-color);
  position: sticky;
  top: 0;
  z-index: 100;
}

/* ====== жңӘзҷ»еҪ•зҠ¶жҖ?====== */
.login-banner {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 120rpx 24rpx;
  min-height: 60vh;
}

.login-content {
  display: flex;
  flex-direction: column;
  align-items: center;
  text-align: center;
}

.login-btn {
  margin-top: 40rpx;
  width: 400rpx;
}

.filter-types-scroll {
  flex: 1;
  white-space: nowrap;
}

.filter-types {
  display: flex;
  flex-direction: row;
}

.filter-type-item {
  display: inline-flex;
  padding: 10rpx 24rpx;
  margin-right: 12rpx;
  border-radius: 20rpx;
  font-size: 26rpx;
  color: var(--text-secondary);
  background: var(--bg-primary);
  border: 1px solid var(--border-color);
  transition: all 0.2s;
  flex-shrink: 0;
}

.filter-type-item.active {
  background: var(--accent-light);
  color: var(--accent);
  border-color: var(--accent);
}

.filter-more {
  display: flex;
  align-items: center;
  padding: 10rpx 16rpx;
  flex-shrink: 0;
  margin-left: 8rpx;
}

/* й«ҳзә§зӯӣйҖүйқўжқ?*/
.filter-panel {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.5);
  z-index: 200;
  display: flex;
  flex-direction: column;
  justify-content: flex-start;
  padding-top: 100rpx;
}

.filter-panel-content {
  max-height: 70vh;
  overflow-y: auto;
}

/* ең°еӣҫзӯӣйҖ?*/
.map-filter-scroll {
  white-space: nowrap;
}

.map-filter-list {
  display: flex;
  flex-direction: row;
}

.map-filter-item {
  display: inline-flex;
  padding: 10rpx 20rpx;
  margin-right: 12rpx;
  border-radius: 20rpx;
  font-size: 24rpx;
  color: var(--text-secondary);
  background: var(--bg-primary);
  border: 1px solid var(--border-color);
  flex-shrink: 0;
}

.map-filter-item.active {
  background: var(--accent-light);
  color: var(--accent);
  border-color: var(--accent);
}

/* д»·ж јиҫ“е…Ҙ */
.price-filter-input {
  padding: 16rpx;
  background: var(--bg-primary);
  border: 2rpx solid var(--border-color);
  border-radius: var(--border-radius-sm);
  font-size: 26rpx;
  color: var(--text-primary);
  text-align: center;
}

.filter-actions {
  gap: 16rpx;
}

/* и®ўеҚ•ж»ҡеҠЁеҢәеҹҹ */
.order-scroll {
  height: calc(100vh - 100rpx);
}

.order-list {
  padding-top: 8rpx;
}

/* жӮ¬жө®еҸ‘еёғжҢүй’® */
.publish-fab {
  position: fixed;
  right: 40rpx;
  bottom: 120rpx;
  width: 100rpx;
  height: 100rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #4D9FFF, #3B7FD9);
  display: flex;
  align-items: center;
  justify-content: center;
  color: #0A0E17;
  font-weight: bold;
  box-shadow: 0 8rpx 24rpx rgba(77, 159, 255, 0.4);
  z-index: 100;
}

