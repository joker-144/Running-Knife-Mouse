/* pages/orderDetail/orderDetail.wxss - и®ўеҚ•иҜҰжғ…ж ·ејҸ */

.detail-header {
  background: var(--bg-card);
  border-bottom: 1px solid var(--border-color);
  padding: 8rpx 0;
}

/* иҜҰжғ…иЎ?*/
.detail-row {
  display: flex;
  flex-direction: row;
  justify-content: space-between;
  align-items: center;
  padding: 16rpx 0;
  border-bottom: 1px solid rgba(255,255,255,0.04);
}

.detail-row:last-child {
  border-bottom: none;
}

.detail-label {
  font-size: 26rpx;
  flex-shrink: 0;
}

.detail-value {
  font-size: 26rpx;
  text-align: right;
  max-width: 60%;
  word-break: break-all;
}

/* зј©з•ҘеӣҫеҲ—иЎ?*/
.image-list {
  display: flex;
  flex-direction: row;
  flex-wrap: wrap;
  gap: 12rpx;
}

.detail-image {
  width: 200rpx;
  height: 200rpx;
  border-radius: var(--border-radius-sm);
  background: var(--bg-primary);
}

/* ж—¶й—ҙзә?*/
.timeline {
  padding-left: 8rpx;
}

.timeline-item {
  display: flex;
  flex-direction: row;
  align-items: flex-start;
  padding-bottom: 24rpx;
  position: relative;
}

.timeline-item::after {
  content: '';
  position: absolute;
  left: 7rpx;
  top: 24rpx;
  bottom: 0;
  width: 2rpx;
  background: var(--border-color);
}

.timeline-item:last-child::after {
  display: none;
}

.timeline-dot {
  width: 16rpx;
  height: 16rpx;
  border-radius: 50%;
  background: #4D9FFF;
  flex-shrink: 0;
  margin-top: 4rpx;
}

/* еә•йғЁж“ҚдҪңж ?*/
.bottom-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  display: flex;
  flex-direction: row;
  align-items: center;
  padding: 16rpx 24rpx;
  background: var(--bg-card);
  border-top: 1px solid var(--border-color);
  z-index: 100;
}

.bottom-bar .btn-sm {
  padding: 20rpx 0;
  font-size: 28rpx;
  text-align: center;
  border-radius: 8rpx;
}

.chat-btn {
  width: 80rpx;
  flex: none !important;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 36rpx;
  margin-left: 8rpx;
}

.btn-warning {
  background: linear-gradient(135deg, #F39C12, #E67E22);
  color: #FFFFFF;
  border-radius: 8rpx;
  border: none;
  font-weight: 600;
  font-size: 28rpx;
  padding: 20rpx 0;
  text-align: center;
}
