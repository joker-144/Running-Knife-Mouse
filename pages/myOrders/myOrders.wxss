/* pages/myOrders/myOrders.wxss - 我的订单样式 */

.tab-scroll {
  position: sticky;
  top: 0;
  z-index: 100;
  background: var(--bg-card);
  border-bottom: 1px solid var(--border-color);
  white-space: nowrap;
}

.tab-list {
  display: flex;
  flex-direction: row;
  padding: 0 16rpx;
}

.tab-item {
  display: inline-flex;
  padding: 20rpx 20rpx;
  font-size: 26rpx;
  color: var(--text-secondary);
  position: relative;
  flex-shrink: 0;
}

.tab-item.active {
  color: var(--accent);
  font-weight: 600;
}

.tab-item.active::after {
  content: '';
  position: absolute;
  bottom: 0;
  left: 20rpx;
  right: 20rpx;
  height: 4rpx;
  background: var(--accent);
  border-radius: 2rpx;
}

.order-scroll {
  height: calc(100vh - 90rpx);
}

.order-list {
  padding-top: 8rpx;
}
