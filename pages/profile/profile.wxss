/* pages/profile/profile.wxss - 个人中心样式 */

/* 未登录 */
.login-banner {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 120rpx 24rpx;
  min-height: 60vh;
}

.login-content {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.login-btn {
  margin-top: 40rpx;
  width: 400rpx;
}

/* 用户信息卡片 */
.profile-card {
  background: linear-gradient(135deg, #1A2435, #151E2C);
  margin: 24rpx;
  padding: 32rpx 24rpx;
  border-radius: var(--border-radius);
  border: 1px solid var(--border-color);
}

.profile-header {
  align-items: center;
}

.avatar-btn {
  padding: 0;
  margin: 0;
  background: transparent;
  border: none;
  line-height: 1;
}

.avatar-btn::after {
  border: none;
}

.nickname-row {
  display: flex;
  align-items: center;
  color: var(--text-primary);
  font-weight: 600;
}

.verify-status {
  padding: 16rpx;
  background: var(--bg-primary);
  border-radius: var(--border-radius-sm);
}

/* 数据概览 */
.stats-card {
  margin: 16rpx 24rpx;
}

.stats-grid {
  display: flex;
  flex-direction: row;
  align-items: center;
  border-bottom: 1px solid var(--border-color);
}

.stats-grid:last-child {
  border-bottom: none;
}

.stat-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 8rpx 0;
  border-radius: var(--border-radius-sm);
  transition: background 0.15s;
}

.stat-clickable:active {
  background: rgba(245, 166, 35, 0.08);
}

.stat-value {
  font-size: 32rpx;
  font-weight: 700;
}

.stat-label {
  margin-top: 4rpx;
  font-size: 20rpx;
}

.stat-divider {
  width: 2rpx;
  height: 40rpx;
  background: var(--border-color);
  align-self: center;
}

/* 功能菜单 */
.menu-list {
  margin: 16rpx 24rpx;
  background: var(--bg-card);
  border-radius: var(--border-radius);
  border: 1px solid var(--border-color);
  overflow: hidden;
}

.menu-item {
  padding: 28rpx 24rpx;
  border-bottom: 1px solid var(--border-color);
}

.menu-item:last-child {
  border-bottom: none;
}

.menu-icon {
  font-size: 36rpx;
}

/* 版本信息 */
.version-info {
  text-align: center;
  padding: 40rpx 0;
  margin-bottom: 40rpx;
}

/* ====== 弹窗样式 ====== */
.modal-overlay {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.6);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 9999;
}

.modal-box {
  width: 580rpx;
  background: #1A2435;
  border-radius: 16rpx;
  border: 1px solid #2A3A50;
  overflow: hidden;
}

.modal-header {
  padding: 32rpx 32rpx 16rpx;
  text-align: center;
}

.modal-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #E8ECF1;
}

.modal-body {
  padding: 16rpx 32rpx 24rpx;
}

.modal-input {
  width: 100%;
  height: 80rpx;
  padding: 0 20rpx;
  background: #0D1520;
  border: 1px solid #2A3A50;
  border-radius: 12rpx;
  color: #E8ECF1;
  font-size: 28rpx;
  box-sizing: border-box;
}

.modal-footer {
  display: flex;
  border-top: 1px solid #2A3A50;
}

.modal-btn {
  flex: 1;
  height: 96rpx;
  line-height: 96rpx;
  text-align: center;
  font-size: 30rpx;
  border: none;
  border-radius: 0;
  background: transparent;
  padding: 0;
}

.modal-btn::after {
  border: none;
}

.modal-btn-cancel {
  color: #8899AA;
  border-right: 1px solid #2A3A50;
}

.modal-btn-confirm {
  color: #F5A623;
  font-weight: 600;
}
