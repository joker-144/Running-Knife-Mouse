/* pages/admin/admin.wxss - 管理后台样式 */

.header-banner {
  text-align: center;
  padding: 40rpx;
}

.user-item {
  padding-bottom: 24rpx;
}

.image-row {
  display: flex;
  flex-direction: row;
  gap: 8rpx;
  flex-wrap: wrap;
}

.verify-thumb {
  width: 120rpx;
  height: 120rpx;
  border-radius: 8rpx;
  background: var(--bg-primary);
}

.btn-danger {
  background: linear-gradient(135deg, #E74C3C, #C0392B);
  color: #FFFFFF;
  border-radius: 8rpx;
  border: none;
  font-size: 26rpx;
  padding: 16rpx 0;
  text-align: center;
}
