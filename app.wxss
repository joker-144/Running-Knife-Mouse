/**app.wxss - 跑刀鼠全局样式 **/

/* 主题色变量 */
page {
  --bg-primary: #0A0F1A;
  --bg-card: #141929;
  --bg-card-hover: #1A2032;
  --accent: #4D9FFF;
  --accent-light: rgba(77, 159, 255, 0.15);
  --success: #00C781;
  --danger: #FF5252;
  --warning: #FFB547;
  --info: #4D9FFF;
  --text-primary: #EAECF0;
  --text-secondary: #8892A4;
  --text-muted: #4E5566;
  --border-color: rgba(255, 255, 255, 0.06);
  --border-radius: 16rpx;
  --border-radius-sm: 8rpx;

  background-color: var(--bg-primary);
  color: var(--text-primary);
  font-size: 28rpx;
  font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
  line-height: 1.5;
  box-sizing: border-box;
}

/* 全局页面容器 */
.page-container {
  min-height: 100vh;
  background-color: var(--bg-primary);
  padding-bottom: 20rpx;
}

/* 卡片样式 */
.card {
  background: var(--bg-card);
  border-radius: var(--border-radius);
  border: 1px solid var(--border-color);
  margin: 16rpx 24rpx;
  padding: 24rpx;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.3);
}

.card-glass {
  background: rgba(21, 30, 44, 0.85);
  backdrop-filter: blur(10px);
  -webkit-backdrop-filter: blur(10px);
  border-radius: var(--border-radius);
  border: 1px solid rgba(255, 255, 255, 0.1);
  margin: 16rpx 24rpx;
  padding: 24rpx;
}

/* 按钮样式 */
.btn-primary {
  background: linear-gradient(135deg, #F5A623, #E8951A);
  color: #0A0E17;
  border-radius: 8rpx;
  border: none;
  font-weight: 600;
  font-size: 30rpx;
  padding: 20rpx 0;
  text-align: center;
  display: flex;
  align-items: center;
  justify-content: center;
}

.btn-primary:active {
  opacity: 0.8;
  transform: scale(0.98);
}

.btn-outline {
  background: transparent;
  color: var(--accent);
  border: 2rpx solid var(--accent);
  border-radius: 8rpx;
  font-weight: 600;
  font-size: 28rpx;
  padding: 16rpx 0;
  text-align: center;
  display: flex;
  align-items: center;
  justify-content: center;
}

.btn-danger {
  background: linear-gradient(135deg, #E74C3C, #C0392B);
  color: #FFFFFF;
  border-radius: 8rpx;
  border: none;
  font-weight: 600;
  font-size: 28rpx;
  padding: 20rpx 0;
  text-align: center;
}

.btn-success {
  background: linear-gradient(135deg, #2ECC71, #27AE60);
  color: #FFFFFF;
  border-radius: 8rpx;
  border: none;
  font-weight: 600;
  font-size: 28rpx;
  padding: 20rpx 0;
  text-align: center;
}

.btn-disabled {
  background: #2A3344;
  color: #5A6A7A;
  border-radius: 8rpx;
  border: none;
  font-weight: 600;
  font-size: 28rpx;
  padding: 20rpx 0;
  text-align: center;
}

.btn-sm {
  padding: 12rpx 32rpx;
  font-size: 24rpx;
  border-radius: 6rpx;
}

/* Flex 布局工具类 */
.flex-row {
  display: flex;
  flex-direction: row;
  align-items: center;
}

.flex-col {
  display: flex;
  flex-direction: column;
}

.flex-between {
  display: flex;
  flex-direction: row;
  align-items: center;
  justify-content: space-between;
}

.flex-center {
  display: flex;
  align-items: center;
  justify-content: center;
}

.flex-1 {
  flex: 1;
}

/* 文字工具类 */
.text-primary { color: var(--text-primary); }
.text-secondary { color: var(--text-secondary); }
.text-muted { color: var(--text-muted); }
.text-accent { color: var(--accent); }
.text-success { color: var(--success); }
.text-danger { color: var(--danger); }
.text-warning { color: var(--warning); }
.text-center { text-align: center; }
.text-bold { font-weight: 600; }
.text-sm { font-size: 24rpx; }
.text-xs { font-size: 20rpx; }
.text-lg { font-size: 32rpx; }
.text-xl { font-size: 36rpx; }
.text-xxl { font-size: 44rpx; }

/* Margin & Padding */
.mt-8 { margin-top: 8rpx; }
.mt-16 { margin-top: 16rpx; }
.mt-24 { margin-top: 24rpx; }
.mt-32 { margin-top: 32rpx; }
.mb-8 { margin-bottom: 8rpx; }
.mb-16 { margin-bottom: 16rpx; }
.mb-24 { margin-bottom: 24rpx; }
.ml-8 { margin-left: 8rpx; }
.mr-8 { margin-right: 8rpx; }
.p-24 { padding: 24rpx; }
.px-24 { padding-left: 24rpx; padding-right: 24rpx; }
.py-16 { padding-top: 16rpx; padding-bottom: 16rpx; }

/* 标签样式 */
.tag {
  display: inline-flex;
  align-items: center;
  padding: 4rpx 16rpx;
  border-radius: 20rpx;
  font-size: 22rpx;
  font-weight: 500;
}

.tag-pending {
  background: rgba(245, 166, 35, 0.15);
  color: #F5A623;
}

.tag-accepted {
  background: rgba(52, 152, 219, 0.15);
  color: #3498DB;
}

.tag-ongoing {
  background: rgba(46, 204, 113, 0.15);
  color: #2ECC71;
}

.tag-completed {
  background: rgba(160, 176, 192, 0.15);
  color: #A0B0C0;
}

.tag-settled {
  background: rgba(46, 204, 113, 0.2);
  color: #2ECC71;
}

.tag-cancelled {
  background: rgba(231, 76, 60, 0.15);
  color: #E74C3C;
}

/* 分隔线 */
.divider {
  height: 1rpx;
  background: var(--border-color);
  margin: 20rpx 0;
}

/* 头像 */
.avatar {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  overflow: hidden;
  flex-shrink: 0;
}

.avatar-sm {
  width: 56rpx;
  height: 56rpx;
}

.avatar-lg {
  width: 120rpx;
  height: 120rpx;
}

/* 图标容器 */
.icon-circle {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 36rpx;
}

/* 空状态 */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 80rpx 0;
}

.empty-state text {
  color: var(--text-muted);
  font-size: 28rpx;
  margin-top: 16rpx;
}

/* 安全区域底部 */
.safe-bottom {
  padding-bottom: constant(safe-area-inset-bottom);
  padding-bottom: env(safe-area-inset-bottom);
}

/* 加载更多 */
.load-more {
  text-align: center;
  padding: 24rpx 0;
  color: var(--text-muted);
  font-size: 24rpx;
}
